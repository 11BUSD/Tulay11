# Postgres connection string used by db:migrate / db:reset / db:seed scripts
# and (via Supabase) the app. Point at your local/Supabase Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tulay

# Optional: separate Postgres for the Vitest integration suite. The test harness
# (src/test/global-setup.ts) creates this DB if missing, then applies migrations
# + seed to it before integration tests run. Falls back to DATABASE_URL. When
# neither is set, integration suites are skipped (unit tests still run).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tulay_test

# Supabase project URL + keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key for the concierge / agents.
OPENAI_API_KEY=your-openai-key

# HMAC pepper for hashing referral IP addresses (data minimization).
REFERRAL_IP_PEPPER=change-me-referral-pepper

# Salt for compliance hashing (consent / PII), version-prefixed v1:.
COMPLIANCE_HASH_SALT=change-me-compliance-salt
